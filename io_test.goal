# Basic I/O and Declarations Test
import arena

score kickoff:
    player athlete_name
    score current_score
    distance sprint_distance = 100.0

    shout "Enter athlete name: "
    receive athlete_name
    
    shout "Enter their score: "
    receive current_score

    shout "Athlete " + athlete_name + " achieved a score of " + current_score
    shout "Standard Sprint: " + sprint_distance
